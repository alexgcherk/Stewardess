{
  "AllowedHosts": "*",
  "Urls": "http://+:55703",

  "Mcp": {
    "RepositoryRoot": "C:\\Temp",
    "ReadOnlyMode": false,
    "ApiKey": "",
    "AllowedIPs": "",
    "RequireApprovalForDestructive": false,

    "MaxFileReadBytes": 5242880,
    "MaxFileSizeForWrite": 10485760,
    "MaxSearchResults": 200,
    "MaxDirectoryDepth": 10,
    "MaxCommandExecutionSeconds": 60,
    "MaxDirectoryEntries": 500,

    "BlockedFolders": ".git,bin,obj,.vs,packages,node_modules,.idea,.vscode,TestResults,.nuget,.mcp_backups,.mcp",
    "AllowedExtensions": "",
    "BlockedExtensions": ".exe,.dll,.pdb,.msi,.zip,.7z,.rar,.tar,.gz,.bz2,.bin,.cache,.suo,.user",
    "AllowedCommands": "dotnet build,dotnet test,dotnet restore,msbuild,git status,git diff,git log,git show,git stash",

    "EnableAuditLog": true,
    "AuditLogPath": "",
    "EnableBackups": true,
    "BackupDirectory": "",
    "MaxBackupsPerFile": 10,

    "LogLevel": "Info",
    "ServiceVersion": "2.0.0"
  },

  "NLog": {
    "throwConfigExceptions": true,
    "targets": {
      "console": {
        "type": "Console",
        "layout": "${date:format=HH\\:mm\\:ss} ${level:uppercase=true:padding=-5} [${logger:shortName=true}] ${message} ${exception:format=tostring}"
      },
      "file": {
        "type": "File",
        "fileName": "${basedir}/logs/mcp-${shortdate}.log",
        "layout": "${longdate}|${level:uppercase=true}|${logger}|${message}|${exception:format=tostring}",
        "keepFileOpen": false
      }
    },
    "rules": [
      { "logger": "Microsoft.*", "maxLevel": "Info", "final": true },
      { "logger": "*", "minLevel": "Info", "writeTo": "console,file" }
    ]
  }
}

<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=169433
  -->
<configuration>
  <!-- ═══════════════════════════════════════════════════════════════════════════
       MCP Service configuration
       Copy this section and update values for your environment.
       All keys are prefixed with "Mcp:".
  ═══════════════════════════════════════════════════════════════════════════ -->
  <appSettings>
    <!-- REQUIRED: Absolute path to the repository root on this machine -->
    <add key="Mcp:RepositoryRoot" value="C:\repos\alexsRepo" />

    <!-- When true, all write/edit operations are rejected -->
    <add key="Mcp:ReadOnlyMode" value="false" />

    <!-- API key auth: leave empty to disable. Clients send X-Api-Key: <value> -->
    <add key="Mcp:ApiKey" value="" />

    <!-- Comma-separated IP allowlist. Leave empty to allow all local IPs. -->
    <add key="Mcp:AllowedIps" value="127.0.0.1,::1" />

    <!-- Max bytes read for a single file (default 5 MB) -->
    <add key="Mcp:MaxFileReadBytes" value="5242880" />

    <!-- Max search results returned in one call -->
    <add key="Mcp:MaxSearchResults" value="200" />

    <!-- Maximum depth for list_tree -->
    <add key="Mcp:MaxDirectoryDepth" value="10" />

    <!-- Timeout in seconds for build/test/command calls -->
    <add key="Mcp:MaxCommandExecutionSeconds" value="120" />

    <!-- Comma-separated list of allowed commands (prefix match).
         Example: dotnet build,dotnet test,msbuild -->
    <add key="Mcp:AllowedCommands" value="dotnet build,dotnet test,dotnet restore" />

    <!-- Comma-separated blocked folders (relative names, not paths) -->
    <add key="Mcp:BlockedFolders" value=".git,bin,obj,.vs,packages,node_modules,.mcp,.mcp_backups" />

    <!-- Comma-separated blocked extensions (include the dot) -->
    <add key="Mcp:BlockedExtensions" value=".exe,.dll,.pdb,.suo,.user" />

    <!-- Comma-separated allowed file extensions for writes.
         Empty = allow all (subject to BlockedExtensions). -->
    <add key="Mcp:AllowedWriteExtensions" value="" />

    <!-- Require an approval token for destructive ops (delete, overwrite) -->
    <add key="Mcp:ApprovalRequiredForDestructive" value="false" />

    <!-- How long (seconds) an approval token remains valid -->
    <add key="Mcp:ApprovalTokenLifetimeSeconds" value="120" />

    <!-- Audit log: true to enable append-only NDJSON audit trail -->
    <add key="Mcp:EnableAuditLog" value="true" />

    <!-- Audit log path; leave empty to use <RepositoryRoot>/.mcp/audit.log -->
    <add key="Mcp:AuditLogPath" value="" />

    <!-- Backup directory for pre-edit snapshots; empty = <RepositoryRoot>/.mcp/backups -->
    <add key="Mcp:BackupDirectory" value="" />

    <!-- Service version string included in health / capabilities responses -->
    <add key="Mcp:ServiceVersion" value="2.0.0" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>

  <system.webServer>
    <!-- Register the OWIN host so IIS passes all requests to the OWIN pipeline -->
    <modules runAllManagedModulesForAllRequests="true" />
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>

  <system.codedom>
    <compilers>
      <compiler language="c#;cs;csharp" extension=".cs"
                type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.CSharpCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=2.0.1.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                warningLevel="4"
                compilerOptions="/langversion:default /nowarn:1659;1699;1701" />
      <compiler language="vb;vbs;visualbasic;vbscript" extension=".vb"
                type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.VBCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=2.0.1.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                warningLevel="4"
                compilerOptions="/langversion:default /nowarn:41008 /define:_MYTYPE=&quot;Web&quot; /optionInfer+" />
    </compilers>
  </system.codedom>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Http" culture="neutral" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.9.0" newVersion="5.2.9.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Net.Http.Formatting" culture="neutral" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.9.0" newVersion="5.2.9.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Owin" culture="neutral" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-4.2.2.0" newVersion="4.2.2.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" culture="neutral" publicKeyToken="30ad4fe6b2a6aeed" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

</configuration>